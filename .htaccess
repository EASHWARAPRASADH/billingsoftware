RewriteEngine On

# 1. Do not interfere with API requests
RewriteRule ^api/ - [L]

# 2. Stop rewriting if the request is already pointing to frontend/build/
RewriteCond %{REQUEST_URI} ^/frontend/build/
RewriteRule ^ - [L]

# 3. If the requested file/directory exists inside frontend/build/, rewrite to it
RewriteCond %{DOCUMENT_ROOT}/frontend/build%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}/frontend/build%{REQUEST_URI} -d
RewriteRule ^(.*)$ frontend/build/$1 [L]

# 4. For any other request (SPA routing), serve the React index.html
RewriteRule ^(.*)$ frontend/build/index.html [L]
